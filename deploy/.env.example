# ============================================================
# Scrapling MCP Server 环境变量配置
# 使用前请复制此文件为 .env 并修改对应配置
# ============================================================

# ---------- 认证配置 ----------
# MCP Server 的 Bearer Token（必须修改！）
# 部署脚本会自动生成一个安全的随机 Token
# 也可以手动指定: openssl rand -hex 32
MCP_AUTH_TOKEN=CHANGE_ME_TO_A_SECURE_RANDOM_TOKEN

# ---------- 服务配置 ----------
# MCP Server 内部监听端口（容器内部端口，一般无需修改）
MCP_PORT=8000

# MCP Server 对外映射端口（仅绑定 127.0.0.1，由 Nginx 代理）
MCP_HOST_PORT=8000

# ---------- 域名配置 ----------
# 你的域名（用于 Nginx 反向代理和 SSL 证书）
MCP_DOMAIN=mcp.yourdomain.com

# ---------- 资源限制 ----------
# Docker 容器 CPU 限制（核心数）
MCP_CPU_LIMIT=4

# Docker 容器内存限制
MCP_MEMORY_LIMIT=4g

# 共享内存大小（Chromium 浏览器需要，建议不低于 2g）
MCP_SHM_SIZE=2g

# ---------- 日志配置 ----------
# Docker 日志大小限制
MCP_LOG_MAX_SIZE=50m

# Docker 日志文件数量限制
MCP_LOG_MAX_FILE=3
